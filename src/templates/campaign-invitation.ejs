<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Campaign Invitation</title>
    <style>
        body {
            font-family: 'Public Sans', sans-serif;
            line-height: 1.6;
            color: #333;
        }

        .container {
            width: 80%;
            margin: 20px auto;
            padding: 20px;
            border: 1px solid #ddd;
            border-radius: 8px;
        }

        .header {
            background: #f4f4f4;
            padding: 20px;
            border-radius: 8px 8px 0 0;
            text-align: center;
        }

        .content {
            padding: 20px;
        }

        .footer {
            font-size: 0.8em;
            text-align: center;
            color: #777;
            margin-top: 20px;
        }

        .btn {
            display: inline-block;
            background: #00DC82;
            color: #fff;
            padding: 12px 24px;
            text-decoration: none;
            border-radius: 8px;
            margin-top: 20px;
            font-weight: bold;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="header">
            <h1 style="color: #00DC82; margin: 0;">You're Invited!</h1>
        </div>
        <div class="content">
            <p>Hello <%= name %>,</p>
            <p><strong>
                    <%= brandName %>
                </strong> has invited you to join their campaign: <strong>"<%= campaignTitle %>"</strong>.</p>
            <p>They think you'd be a great fit for this project. Tap the button below to view the campaign details and
                accept the invitation.</p>
            <div style="text-align: center;">
                <a href="<%= campaignUrl %>" class="btn">View Invitation</a>
            </div>
        </div>
        <div class="footer">
            <p>&copy; 2026 Kollab. All rights reserved.</p>
        </div>
    </div>
</body>

</html>